# LLM API Keys (at least one required)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Semantic Scholar API key (optional, for higher rate limits)
SEMANTIC_SCHOLAR_API_KEY=

# Model configuration
LLM_MODEL=claude-sonnet-4-6
LLM_TEMPERATURE=0.2

# Output settings
OUTPUT_FORMAT=markdown
OUTPUT_DIR=./output
