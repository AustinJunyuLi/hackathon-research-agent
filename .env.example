# --- LLM backend selection ---
# auto      : prefer direct provider keys, fallback to OpenClaw runtime
# openai    : force OpenAI API
# anthropic : force Anthropic API
# openclaw  : force OpenClaw runtime (no provider key env required)
LLM_BACKEND=openclaw

# Optional direct provider keys (only needed for openai/anthropic backend)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional provider-specific model overrides
# If LLM_MODEL does not match the chosen provider, backend defaults are used.
LLM_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-sonnet-4-6
LLM_TEMPERATURE=0.2

# OpenClaw backend tuning (used when LLM_BACKEND=openclaw or auto fallback)
OPENCLAW_LLM_AGENT=main
OPENCLAW_LLM_TIMEOUT_SECONDS=180
# OPENCLAW_LLM_THINKING=low

# Semantic Scholar API key (optional, for higher rate limits)
SEMANTIC_SCHOLAR_API_KEY=

# Output settings
OUTPUT_FORMAT=markdown
OUTPUT_DIR=./output
